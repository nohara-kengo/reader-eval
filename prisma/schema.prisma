// Prisma スキーマ（暫定）。ORM は暫定 Prisma（db.md / ADR 未確定）。
// 評価ドメインのテーブルは要件確定後に追加する。まずは監査ログのみ定義（logging.md §4.3）。
// 命名は naming-conventions.md §4 を正とする（テーブル複数形 snake_case、@map/@@map）。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// アプリ利用を許可されたユーザー（許可リスト）。SSO 認証成立後にここを照合し、
// 該当があればログイン可・なければ拒否する（既定拒否 / authz.md §5）。
// email は小文字へ正規化して保持し、一意制約で重複を防ぐ（naming-conventions.md §4）。
model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// 監査ログ（誰が・いつ・何を・対象）。append-only 運用（logging.md §4.5）。
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  occurredAt DateTime @default(now()) @map("occurred_at")
  actorId    String   @map("actor_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  result     String
  requestId  String?  @map("request_id")
  summary    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([occurredAt])
  @@map("audit_logs")
}

// 評価対象者の区分（等級）マスタ。R / M / S クラス等を管理する（要件 G-03）。
// code は一意。一覧は有効を先頭に sort_order 昇順 → code 昇順で並べる。
model Grade {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("grades")
}

// 評価軸カテゴリ（評価項目を束ねる区分）マスタ（要件 B-03）。
// 「資格 / 技術力 / リーダーシップ / その他（伸びしろ系項目）」等を管理する。
// code は一意。一覧は有効を先頭に sort_order 昇順 → code 昇順で並べる。
model EvaluationAxisCategory {
  id        BigInt           @id @default(autoincrement())
  code      String           @unique
  name      String
  sortOrder Int              @default(0) @map("sort_order")
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  items     EvaluationItem[]

  @@map("evaluation_axis_categories")
}

// 評価項目（評価軸カテゴリに属する個別の評価観点）マスタ（要件 B-03）。
// code はカテゴリ内で一意（@@unique）。カテゴリ削除時は子の評価項目も削除する（Cascade）。
// 一覧は有効を先頭に sort_order 昇順 → code 昇順で並べる。
model EvaluationItem {
  id         BigInt                 @id @default(autoincrement())
  categoryId BigInt                 @map("category_id")
  code       String
  name       String
  sortOrder  Int                    @default(0) @map("sort_order")
  isActive   Boolean                @default(true) @map("is_active")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")
  category   EvaluationAxisCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, code])
  @@index([categoryId])
  @@map("evaluation_items")
}
