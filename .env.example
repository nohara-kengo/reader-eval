# reader-eval 環境変数サンプル（config.md 準拠）
# このファイルをコピーして .env を作成する: cp .env.example .env
# 実値は .env にのみ書く（.env* はコミット/読み取り禁止）。ここには値を書かない。

# --- データベース（PostgreSQL） ---
# アプリからの接続文字列（docker compose 利用時は web から db:5432 へ）
DATABASE_URL=
# docker compose の db サービス初期化用
POSTGRES_DB=reader_eval
POSTGRES_USER=dev
POSTGRES_PASSWORD=

# --- AI（Claude / Anthropic） ---
ANTHROPIC_API_KEY=
# 既定モデル（未指定時は claude-opus-4-8）
ANTHROPIC_MODEL=claude-opus-4-8

# --- 認証（M365 / Entra ID SSO） ---
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# --- アプリ ---
APP_BASE_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
